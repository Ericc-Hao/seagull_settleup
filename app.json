{
  "expo": {
    "name": "Seagull Split",
    "slug": "seagull_split",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF1FF"
    },
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#EEF1FF",
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Seagull Split to choose receipt images and profile photos from your photo library.",
          "cameraPermission": "Allow Seagull Split to take receipt photos."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#EEF1FF"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.anonymous.seagull-split",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Seagull Split to take receipt photos.",
        "NSPhotoLibraryUsageDescription": "Allow Seagull Split to choose receipt images and profile photos from your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#EEF1FF"
      },
      "navigationBar": {
        "backgroundColor": "#EEF1FF"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.seagull_split"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png",
      "backgroundColor": "#EEF1FF"
    }
  }
}
