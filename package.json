{
  "name": "seagull_settleup",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/metro-runtime": "^56.0.12",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@supabase/supabase-js": "2.45.4",
    "expo": "~56.0.8",
    "expo-blur": "~56.0.3",
    "expo-clipboard": "^56.0.3",
    "expo-constants": "~56.0.16",
    "expo-image-picker": "~56.0.15",
    "expo-linear-gradient": "^56.0.4",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-heroicons": "^4.0.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.12",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "preflight:expo": "node scripts/preflight-expo.mjs",
    "start": "npm run preflight:expo && expo start",
    "android": "npm run preflight:expo && expo run:android",
    "ios": "npm run preflight:expo && expo run:ios",
    "ios:release": "npm run preflight:expo && expo run:ios --configuration Release --device generic --output ./build/ios-release",
    "ios:release:device": "npm run preflight:expo && expo run:ios --configuration Release",
    "web": "expo start --web",
    "web:build": "node scripts/generate-aasa.mjs && expo export -p web",
    "web:preview": "npx serve dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run test",
    "upload:email-icon": "npx tsx scripts/upload-email-icon.ts"
  },
  "private": true,
  "engines": {
    "node": "24.3.0",
    "npm": ">=10"
  },
  "overrides": {
    "uuid": "^11.1.0"
  }
}
